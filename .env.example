# ─── FarmWise AI — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# Flask secret key (generate a long random string)
SECRET_KEY=change-me-to-a-long-random-secret

# ── Groq API (AI engine for pest prediction & scheme finder) ────────────────
# Sign up free at: https://console.groq.com
# Models available: llama-3.3-70b-versatile (default), llama3-70b-8192, mixtral-8x7b-32768
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenWeatherMap (7-day weather forecast) ─────────────────────────────────
# Sign up free at: https://home.openweathermap.org/users/sign_up
# Free tier: 60 calls/min, 1,000,000 calls/month — more than enough
# After registering, go to API keys tab and copy your key
OWM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── No extra keys needed ────────────────────────────────────────────────────
# Nominatim / OpenStreetMap (reverse geocoding) — completely free, no key
# Browser SpeechSynthesis (text-to-speech) — built into browser, no key
